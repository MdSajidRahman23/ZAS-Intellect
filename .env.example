# ZAS-Intellect Final Python - Adaptive Viva Demo
APP_NAME=ZAS-Intellect
APP_VERSION=Adaptive Viva Ready
APP_SECRET_KEY=change-this-secret-before-demo
DATABASE_URL=sqlite:///./zas_intellect.db
UPLOAD_DIR=app/data/uploads
RECORDING_DIR=app/data/recordings
MAX_UPLOAD_MB=12
MIN_READABLE_CHARS=80
VIVA_DURATION_MINUTES=5
MIN_ANSWER_CHARS=20

# Adaptive viva: strong answer -> harder next question; weak answer -> easier next question
ENABLE_ADAPTIVE_VIVA=true
ADAPTIVE_QUESTION_COUNT=5
ADAPTIVE_START_DIFFICULTY=2
ADAPTIVE_RAISE_THRESHOLD=75
ADAPTIVE_LOWER_THRESHOLD=50

# AI provider options: auto, grok, gemini, offline
# offline = safest local demo; auto = Grok -> Gemini -> Offline fallback
AI_PROVIDER=auto
AI_TIMEOUT_SECONDS=10
AI_PRIVACY_NOTICE=true

# Grok / xAI API (optional)
XAI_API_KEY=
XAI_BASE_URL=https://api.x.ai/v1
XAI_MODEL=grok-4.3

# Gemini backup (optional)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# Speech-to-text
# browser = Web Speech API in Chrome/Edge
# openai = server-side Whisper endpoint (/api/stt) using OPENAI_API_KEY
STT_PROVIDER=browser
OPENAI_API_KEY=
OPENAI_STT_MODEL=whisper-1

# Secure proctoring
ENABLE_SECURE_FULLSCREEN=true
SECURE_MODE_END_ON_FULLSCREEN_EXIT=true
SECURE_MODE_END_ON_FOCUS_LOSS=true
ENABLE_VIDEO_RECORDING=true
VIDEO_CHUNK_SECONDS=10
MAX_RECORDING_CHUNK_MB=18
KEEP_RECORDINGS_FOR_ALL_SESSIONS=true
ENABLE_MEDIAPIPE_PROCTORING=true
MOTION_DETECTION_ENABLED=true
MOTION_DETECTION_INTERVAL_MS=2500

# Demo / production
DEMO_MODE=true
PRODUCTION_MODE=false
SHOW_DEMO_CREDENTIALS=true
LOGIN_RATE_LIMIT_ATTEMPTS=5
LOGIN_RATE_LIMIT_WINDOW_SECONDS=300
SESSION_TIMEOUT_MINUTES=45
SECURE_COOKIES=false
TEACHER_SCOPE_MODE=department

# Optional PDF font override if Bangla PDF text does not render on your Windows PC
# ZAS_PDF_FONT_REGULAR=C:\Windows\Fonts\Nirmala.ttf
# ZAS_PDF_FONT_BOLD=C:\Windows\Fonts\NirmalaB.ttf
